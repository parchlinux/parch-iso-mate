! basic X11 stuff {{{
Xft.dpi:       115
Xft.antialias: true
Xft.hinting:   true
Xft.rgba:      rgba
Xft.autohint:  true
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault

Xcursor.theme:       Simp1e
Xcursor.size:        0
! }}}

! (n)sxiv {{{
SXiv*faceSize:          45
NSxiv*faceSize:          45
! }}}

! xterm {{{
!XTerm*background:        #111111
!XTerm*foreground:        #b8b9b4
!XTerm*pointerColor:      #1ABB9B
XTerm*borderColor:       #b8b9b4
XTerm*faceName:          Liberation Mono
XTerm*faceSize:          16
XTerm*reverseVideo:      off
XTerm*selectToClipboard: true
XTerm*geometry:          80x28
XTerm*SaveLines:         2000
XTerm*rightScrollBar:    false
XTerm*ScrollBar:         false
XTerm*scrollTtyOutput:   false
XTerm*VT100.Translations: #override \
  Shift Ctrl<Key>V: insert-selection(CLIPBOARD)
  Shift Ctrl<Key>V: insert-selection(PRIMARY)
  Shift<Btn1Down>: select-start()
  Shift<Btn1Motion>: select-extend()
  Shift<Btn1Up>: select-end(CLIPBOARD)

! colorschemes {{{
!*pointerColorBackground:          #2B2C2B
!*pointerColorForeground:          #16A085
!*fading:                          8
!*fadeColor:                       black
!*cursorColor:                    #D64601
!*cursorColor:                    #3eff00

!*background:                     #030303
!*foreground:                     #b8b9b4
*cursorColor:                    #ff7700

